{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "server.js",
      "framework": "node"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/_/backend/api/$1" }
  ]
}